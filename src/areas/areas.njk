{# ========== SERVICE AREAS INDEX ========== #}

<header class="ohero noimg slim">
  <div class="wrap"><div class="ohero-inner stagger">
    <span class="lab">Where we build</span>
    <h1>Service Areas</h1>
    <p class="lead">We build in Oakland, Genesee, Lapeer, and Macomb counties. Home base is Clarkston, and the crews come to you.</p>
    <div class="hero-cta">
      <a href="/contact/" class="btn btn-green">Get a Free Estimate</a>
    </div>
  </div></div>
</header>

<section class="blk"><div class="wrap">
  <div class="head reveal"><h2>Communities we serve</h2><p>Don't see your town listed? Call us, we may still cover your area.</p></div>
  {% set countyNotes = [
    { name: "Oakland", note: "Home base. Clarkston, the lake towns, and the horse country in the north of the county." },
    { name: "Genesee", note: "Fenton, Grand Blanc, and the townships south of Flint." },
    { name: "Lapeer", note: "Farm and horse country: the city of Lapeer, Metamora, and the townships around them." },
    { name: "Macomb", note: "The rural west side of the county, around Romeo and Washington Township." },
    { name: "Livingston", note: "A westward stretch of our range, centered on Howell." }
  ] %}
  {% for c in countyNotes %}
  <div class="head reveal" style="margin-top:28px"><h3>{{ c.name }} County</h3><p>{{ c.note }}</p></div>
  <div class="areas stagger">
    {% for area in collections.areas %}{% if area.data.county == c.name %}<a href="{{ area.url }}">{{ area.data.city }}</a>{% endif %}{% endfor %}
  </div>
  {% endfor %}
</div></section>

<section class="blk cta"><div class="wrap"><div class="box reveal">
  <h2>Ready to build in your area?</h2>
  <p>Get a free, no-obligation estimate. Call today or send us the details and we will come take a look.</p>
  <div class="row">
    <a href="/contact/" class="btn btn-dark">Get a Free Estimate</a>
    <a href="tel:{{ site.phoneTel }}" class="btn btn-ghost" style="border-color:rgba(13,36,21,.3);color:#0d2415">Call {{ site.phone }}</a>
  </div>
</div></div></section>
