---
layout: layouts/base.njk
---

{# ===== post hero ===== #}
<header class="phero">
  <div class="wrap">
    <div class="lab">{{ category or "Guides" }}</div>
    <h1>{{ title }}</h1>
    <div class="pmeta">
      <span>By <b>{{ author or "CNO Pole Barns" }}</b></span>
      <span>{{ date | dateFormat }}</span>
    </div>
  </div>
</header>

{# ===== article + sidebar ===== #}
<div class="artwrap">
  <article class="article reveal">
    {{ content | safe }}
    {% if faq %}
    <h2>Common questions</h2>
    <div class="faqwrap stagger">
      {% for item in faq %}
      <div class="faq"><div class="faq-q">{{ item.q }}</div><div class="faq-a"><p>{{ item.a }}</p></div></div>
      {% endfor %}
    </div>
    {% endif %}
  </article>

  <aside class="aside">
    <div class="scard hi">
      <h4>Thinking about a building?</h4>
      <p>Tell us what you want to build and we will come take a look. Free estimate, no pressure.</p>
      <a class="btn btn-gold" href="/contact/">Request an estimate</a>
      <a class="btn btn-line" href="tel:{{ site.phoneTel }}">Call {{ site.phone }}</a>
    </div>
    <div class="scard">
      <h4>More reading</h4>
      <ul class="qlinks">
        {% for post in collections.blog | limit(5) %}{% if post.url != page.url %}<a href="{{ post.url }}">{{ post.data.title }} <span>&rarr;</span></a>{% endif %}{% endfor %}
      </ul>
    </div>
  </aside>
</div>

{# ===== related posts ===== #}
<section class="blk tight tint">
  <div class="wrap">
    <div class="head reveal"><h2>Keep reading</h2></div>
    <div class="bloggrid stagger">
      {% for post in collections.blog | limit(4) %}
      {% if post.url != page.url %}
      <a href="{{ post.url }}" class="bcard">
        {% if post.data.image %}<div class="im"><img src="{{ post.data.image }}" alt="{{ post.data.title }}" loading="lazy"></div>{% endif %}
        <div class="bd">
          <span class="meta">{{ post.data.category or "Guides" }}</span>
          <h3>{{ post.data.title }}</h3>
          <p>{{ post.templateContent | excerpt }}</p>
        </div>
      </a>
      {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% include "partials/schema-breadcrumb.njk" %}

{# ===== json-ld: blogposting ===== #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ title | dump | safe }},
  "description": {{ description | dump | safe }},
  {% if image %}"image": {{ (site.url + image) | dump | safe }},{% endif %}
  "datePublished": {{ date | dateISO | dump | safe }},
  "dateModified": {{ (updated or date) | dateISO | dump | safe }},
  "author": {
    "@type": "Organization",
    "name": {{ site.name | dump | safe }},
    "url": {{ site.url | dump | safe }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ site.name | dump | safe }},
    "logo": { "@type": "ImageObject", "url": {{ (site.url + "/images/logos/cno-green-light-bg.png") | dump | safe }} }
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": {{ (site.url + page.url) | dump | safe }} }
}
</script>

{# ===== json-ld: faqpage ===== #}
{% if faq %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in faq %}{
      "@type": "Question",
      "name": {{ item.q | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ item.a | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}
