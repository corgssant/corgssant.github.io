<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script>document.documentElement.classList.add('js');</script>
  {% include "partials/analytics.njk" %}
  <title>{{ seoTitle or title }} | {{ site.name }}</title>
  <meta name="description" content="{{ description }}">
  {% if noindex %}<meta name="robots" content="noindex">{% endif %}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <meta property="og:title" content="{{ seoTitle or title }} | {{ site.name }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}{{ image or '/images/og-card.png' }}">
  <meta property="og:image:alt" content="{{ imageAlt or site.name }}">
  {% if not image %}<meta property="og:image:width" content="1200"><meta property="og:image:height" content="630">{% endif %}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="theme-color" content="#182619">
  <link rel="icon" type="image/png" sizes="64x64" href="/images/favicon-green.png">
  <link rel="icon" type="image/png" sizes="64x64" href="/images/favicon-white.png" media="(prefers-color-scheme: dark)">
  <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png">
  <link rel="preload" href="/fonts/barlow-cond-700.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/barlow-500.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/sserif-400.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/style.css">
  {% include "partials/schema-localbusiness.njk" %}
  {% block head %}{% endblock %}
</head>
<body>
  {% include "partials/nav.njk" %}
  {% block content %}{{ content | safe }}{% endblock %}
  {% include "partials/footer.njk" %}
  <script src="/js/main.js"></script>
</body>
</html>
