---
layout: layouts/base.njk
---

{% set crumbs = [{name:"Home",url:"/"},{name:"Services",url:"/services/"},{name:title,url:page.url}] %}

{# ===== page hero ===== #}
<header class="phero svc-hero"><div class="wrap">
  <div class="crumbs">{% for c in crumbs %}{% if not loop.last %}<a href="{{ c.url }}">{{ c.name }}</a> <span>/</span> {% else %}<span>{{ c.name }}</span>{% endif %}{% endfor %}</div>
  <span class="lab">{{ category }}</span>
  <h1>{{ title }}</h1>
  <p class="lead">{{ subtitle }}</p>
  <div class="hero-cta">
    <a href="/contact/" class="btn btn-dark">Get a Free Estimate</a>
    <a href="tel:{{ site.phoneTel }}" class="btn btn-ghost">Call {{ site.phone }}</a>
  </div>
</div></header>

{# ===== intro: detail content + image ===== #}
<section class="blk"><div class="wrap"><div class="split">
  <div class="split-img"><img src="{{ image }}" alt="{{ title }}"></div>
  <div>
    <div class="detail">{{ content | safe }}</div>
    {% if features %}
    <ul class="flist">
      {% for f in features %}<li>{{ f }}</li>{% endfor %}
    </ul>
    {% endif %}
    <a href="/contact/" class="btn btn-dark">Get a Free Estimate</a>
  </div>
</div></div></section>

{# ===== gallery ===== #}
{% if gallery %}
<section class="blk tint"><div class="wrap">
  <div class="head"><span class="lab">Gallery</span><h2>Recent {{ title }} projects</h2></div>
  <div class="ggrid">
    {% for g in gallery %}
    <figure>
      <img src="{{ g.src }}" alt="{{ g.alt or title }}">
      {% if g.caption %}<figcaption>{{ g.caption }}</figcaption>{% endif %}
    </figure>
    {% endfor %}
  </div>
</div></section>
{% endif %}

{# ===== faq ===== #}
{% if faq %}
<section class="blk"><div class="wrap">
  <div class="head"><span class="lab">FAQ</span><h2>Common questions about {{ title }}</h2></div>
  <div>
    {% for item in faq %}
    <div class="faq">
      <div class="faq-q">{{ item.q }}</div>
      <div class="faq-a"><p>{{ item.a }}</p></div>
    </div>
    {% endfor %}
  </div>
</div></section>
{% endif %}

{# ===== other services ===== #}
<section class="blk tint"><div class="wrap">
  <div class="head"><h2>Other services</h2><p>Explore more of what we build across southeast Michigan.</p></div>
  <div class="svc">
    {% for service in collections.services %}
    {% if service.url != page.url %}
    <a class="card" href="{{ service.url }}">
      <div class="im"><img src="{{ service.data.image }}" alt="{{ service.data.title }}"></div>
      <div class="bd">
        <h3>{{ service.data.title }}</h3>
        <p>{{ service.data.subtitle }}</p>
        <span class="lk">Learn more &rarr;</span>
      </div>
    </a>
    {% endif %}
    {% endfor %}
  </div>
</div></section>

{# ===== cta ===== #}
<section class="blk cta"><div class="wrap"><div class="box">
  <h2>Ready to talk about your {{ title }} project?</h2>
  <p>Get a free, no-obligation estimate. Call today or send us the details and we will come take a look.</p>
  <div class="row">
    <a href="/contact/" class="btn btn-dark">Get a Free Estimate</a>
    <a href="tel:{{ site.phoneTel }}" class="btn btn-ghost" style="border-color:rgba(13,36,21,.3);color:#0d2415">Call {{ site.phone }}</a>
  </div>
</div></div></section>

{# ===== json-ld: service ===== #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "{{ title }}",
  "serviceType": "{{ category }}",
  "provider": {
    "@type": "GeneralContractor",
    "name": "{{ site.name }}",
    "url": "{{ site.url }}",
    "telephone": "{{ site.phone }}"
  },
  "areaServed": [
    {% for c in site.counties %}{ "@type": "AdministrativeArea", "name": "{{ c }} County, MI" }{% if not loop.last %},{% endif %}{% endfor %}
  ]
}
</script>

{# ===== json-ld: breadcrumb ===== #}
{% include "partials/schema-breadcrumb.njk" %}

{# ===== json-ld: faqpage ===== #}
{% if faq %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in faq %}{
      "@type": "Question",
      "name": "{{ item.q }}",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ item.a }}"
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}
