---
layout: layouts/base.njk
---

{% set crumbs = [{name:"Home",url:"/"},{name:"Service Areas",url:"/areas/"},{name:city,url:page.url}] %}
{% set heroImage = heroImage or image or "/images/projects/michigan-farm.webp" %}

{# ===== overlay hero (placeholder project photo; set per-area via heroImage front matter) ===== #}
<header class="ohero">
  <div class="bg"><img src="{{ heroImage }}" alt="{{ imageAlt or "A pole barn built by CNO Pole Barns in Michigan" }}"></div>
  <div class="wrap"><div class="ohero-inner stagger">
    <div class="crumbs">{% for c in crumbs %}{% if not loop.last %}<a href="{{ c.url }}">{{ c.name }}</a> <span>/</span> {% else %}<span>{{ c.name }}</span>{% endif %}{% endfor %}</div>
    <span class="lab">Service Area</span>
    <h1>Pole Barn Builders in {{ city }}, {{ state or "MI" }}</h1>
    {% if subtitle %}<p class="lead">{{ subtitle }}</p>{% endif %}
    <div class="hero-cta">
      <a href="/contact/" class="btn btn-green">Get a Free Estimate</a>
      <a href="tel:{{ site.phoneTel }}" class="btn btn-ghost">Call {{ site.phone }}</a>
    </div>
  </div></div>
</header>

{# ===== article body + sticky sidebar ===== #}
<div class="artwrap">
  <article class="article reveal">
    {{ content | safe }}
    {% if faq %}
    <h2>Common questions in {{ city }}</h2>
    <div class="faqwrap stagger">
      {% for item in faq %}
      <div class="faq"><div class="faq-q">{{ item.q }}</div><div class="faq-a"><p>{{ item.a }}</p></div></div>
      {% endfor %}
    </div>
    {% endif %}
  </article>

  <aside class="aside">
    <div class="scard hi">
      <h4>Get a free estimate</h4>
      <p>Tell us about your {{ city }} project and we will come take a look. No pressure, no obligation.</p>
      <a class="btn btn-green" href="/contact/">Request an estimate</a>
      <a class="btn btn-ghost" href="tel:{{ site.phoneTel }}" style="color:#fff;border-color:rgba(255,255,255,.4)">Call {{ site.phone }}</a>
    </div>
    <div class="scard">
      <h4>Why CNO</h4>
      <ul class="badges">
        <li><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 6 9 17l-5-5"/></svg> A+ BBB Rated</li>
        <li><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 6 9 17l-5-5"/></svg> Licensed &amp; Insured</li>
        <li><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 6 9 17l-5-5"/></svg> Certified Federal Steel Builder</li>
        <li><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 6 9 17l-5-5"/></svg> Building since 1970</li>
      </ul>
    </div>
    <div class="scard">
      <h4>What we build in {{ city }}</h4>
      <ul class="qlinks">
        {% for service in collections.services | limit(5) %}<a href="{{ service.url }}">{{ service.data.title }} <span>&rarr;</span></a>{% endfor %}
      </ul>
    </div>
    <div class="scard">
      <h4>Nearby areas</h4>
      <ul class="qlinks">
        {% if nearby %}
        {% for area in collections.areas %}{% if area.fileSlug in nearby %}<a href="{{ area.url }}">{{ area.data.city }} <span>&rarr;</span></a>{% endif %}{% endfor %}
        {% else %}
        {% for area in collections.areas | limit(7) %}{% if area.url != page.url %}<a href="{{ area.url }}">{{ area.data.city }} <span>&rarr;</span></a>{% endif %}{% endfor %}
        {% endif %}
      </ul>
    </div>
  </aside>
</div>

{# ===== cta ===== #}
<section class="blk cta"><div class="wrap"><div class="box reveal">
  <h2>Ready to build in {{ city }}?</h2>
  <p>Get a free, no-obligation estimate for your {{ city }} project. Call today or send us the details and we will come take a look.</p>
  <div class="row">
    <a href="/contact/" class="btn btn-dark">Get a Free Estimate</a>
    <a href="tel:{{ site.phoneTel }}" class="btn btn-ghost" style="border-color:rgba(13,36,21,.3);color:#0d2415">Call {{ site.phone }}</a>
  </div>
</div></div></section>

{# ===== json-ld: service ===== #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": {{ ("Pole Barn Construction in " + city) | dump | safe }},
  "serviceType": {{ "Pole Barn Construction" | dump | safe }},
  "provider": {
    "@type": "GeneralContractor",
    "name": {{ site.name | dump | safe }},
    "url": {{ site.url | dump | safe }},
    "telephone": {{ site.phone | dump | safe }}
  },
  "areaServed": {
    "@type": "City",
    "name": {{ (city + ", MI") | dump | safe }}
  }
}
</script>

{# ===== json-ld: breadcrumb ===== #}
{% include "partials/schema-breadcrumb.njk" %}

{# ===== json-ld: faqpage ===== #}
{% if faq %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in faq %}{
      "@type": "Question",
      "name": {{ item.q | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ item.a | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}
