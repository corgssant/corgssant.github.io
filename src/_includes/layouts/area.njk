---
layout: layouts/base.njk
---

{% set crumbs = [{name:"Home",url:"/"},{name:"Service Areas",url:"/areas/"},{name:city,url:page.url}] %}

{# ===== page hero ===== #}
<header class="phero svc-hero"><div class="wrap">
  <div class="crumbs">{% for c in crumbs %}{% if not loop.last %}<a href="{{ c.url }}">{{ c.name }}</a> <span>/</span> {% else %}<span>{{ c.name }}</span>{% endif %}{% endfor %}</div>
  <span class="lab">Service Area</span>
  <h1>Pole Barn Builders in {{ city }}, {{ state or "MI" }}</h1>
  <p class="lead">{{ subtitle }}</p>
  <div class="hero-cta">
    <a href="/contact/" class="btn btn-dark">Get a Free Estimate</a>
    <a href="tel:{{ site.phoneTel }}" class="btn btn-ghost">Call {{ site.phone }}</a>
  </div>
</div></header>

{# ===== intro: detail content + image + trust facts ===== #}
<section class="blk"><div class="wrap"><div class="split">
  <div class="split-img"><img src="{{ image }}" alt="{{ title }}"></div>
  <div>
    <div class="detail">{{ content | safe }}</div>
    <ul class="flist">
      {% for t in site.trust %}<li>{{ t }}</li>{% endfor %}
    </ul>
    <a href="/contact/" class="btn btn-dark">Get a Free Estimate</a>
  </div>
</div></div></section>

{# ===== services offered in this area ===== #}
<section class="blk tint"><div class="wrap">
  <div class="head"><h2>Services we offer in {{ city }}, {{ state or "MI" }}</h2><p>From residential garages to commercial buildings, we build the full range of pole barns and steel buildings in the {{ city }} area.</p></div>
  <div class="svc">
    {% for service in collections.services %}
    <a class="card" href="{{ service.url }}">
      <div class="im"><img src="{{ service.data.image }}" alt="{{ service.data.title }}"></div>
      <div class="bd">
        <h3>{{ service.data.title }}</h3>
        <p>{{ service.data.subtitle }}</p>
        <span class="lk">Learn more &rarr;</span>
      </div>
    </a>
    {% endfor %}
  </div>
</div></section>

{# ===== why this city chooses cno ===== #}
{% if whyChoose %}
<section class="blk"><div class="wrap">
  <div class="head"><span class="lab">Why CNO</span><h2>Why {{ city }} chooses CNO</h2></div>
  <div class="steps">
    {% for reason in whyChoose %}
    <div class="s">
      <div class="num">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</div>
      <h3>{{ reason.title }}</h3>
      <p>{{ reason.text }}</p>
    </div>
    {% endfor %}
  </div>
</div></section>
{% endif %}

{# ===== other service areas ===== #}
<section class="blk {% if whyChoose %}tint{% endif %}"><div class="wrap">
  <div class="head"><h2>We also serve</h2><p>Building pole barns across {{ county }} County and neighboring communities throughout southeast Michigan.</p></div>
  <div class="areas">
    {% for area in collections.areas %}
    {% if area.url != page.url %}<a href="{{ area.url }}">{{ area.data.city }}</a>{% endif %}
    {% endfor %}
  </div>
</div></section>

{# ===== cta ===== #}
<section class="blk cta"><div class="wrap"><div class="box">
  <h2>Ready to build in {{ city }}?</h2>
  <p>Get a free, no-obligation estimate for your {{ city }} project. Call today or send us the details and we will come take a look.</p>
  <div class="row">
    <a href="/contact/" class="btn btn-dark">Get a Free Estimate</a>
    <a href="tel:{{ site.phoneTel }}" class="btn btn-ghost" style="border-color:rgba(13,36,21,.3);color:#0d2415">Call {{ site.phone }}</a>
  </div>
</div></div></section>

{# ===== json-ld: service ===== #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": {{ ("Pole Barn Construction in " + city) | dump | safe }},
  "serviceType": {{ "Pole Barn Construction" | dump | safe }},
  "provider": {
    "@type": "GeneralContractor",
    "name": {{ site.name | dump | safe }},
    "url": {{ site.url | dump | safe }},
    "telephone": {{ site.phone | dump | safe }}
  },
  "areaServed": {
    "@type": "City",
    "name": {{ (city + ", MI") | dump | safe }}
  }
}
</script>

{# ===== json-ld: breadcrumb ===== #}
{% include "partials/schema-breadcrumb.njk" %}
