<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {% for c in crumbs %}{
      "@type": "ListItem",
      "position": {{ loop.index }},
      "name": {{ c.name | dump | safe }},
      "item": {{ (site.url + c.url) | dump | safe }}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
