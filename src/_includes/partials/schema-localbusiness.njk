<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "GeneralContractor",
  "name": {{ site.name | dump | safe }},
  "url": {{ site.url | dump | safe }},
  "telephone": {{ site.phone | dump | safe }},
  "email": {{ site.email | dump | safe }},
  "description": {{ (site.name + " builds post-frame pole barns, garages, horse barns, and barndominiums, and is a certified Federal Steel Systems dealer/erector installing pre-engineered steel buildings (commercial, industrial, aircraft hangars, riding arenas, and mini-storage) across southeast Michigan. Locally owned, building since " + site.established + ".") | dump | safe }},
  "priceRange": "$$",
  "image": {{ (site.url + "/images/projects/shop-building.jpg") | dump | safe }},
  "logo": {{ (site.url + "/images/logos/cno-green-light-bg.png") | dump | safe }},
  "foundingDate": "1970",
  "areaServed": [
    {% for c in site.counties %}{ "@type": "AdministrativeArea", "name": {{ (c + " County, MI") | dump | safe }} }{% if not loop.last %},{% endif %}{% endfor %}
  ],
  "openingHours": "Mo-Sa 08:30-19:00",
  "sameAs": [ {{ site.social.google | dump | safe }} ],
  "additionalType": "https://schema.org/HomeAndConstructionBusiness",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Post-Frame & Steel Building Services",
    "itemListElement": [
      {
        "@type": "OfferCatalog",
        "name": "Post-Frame Buildings",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Pole Barns", "url": {{ (site.url + "/services/pole-barns/") | dump | safe }} } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Garages", "url": {{ (site.url + "/services/garages/") | dump | safe }} } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Horse Barns", "url": {{ (site.url + "/services/horse-barns/") | dump | safe }} } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Barndominiums", "url": {{ (site.url + "/services/barndominiums/") | dump | safe }} } }
        ]
      },
      {
        "@type": "OfferCatalog",
        "name": "Pre-Engineered Steel Buildings",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Commercial Steel Buildings", "url": {{ (site.url + "/steel-buildings/commercial/") | dump | safe }} } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Industrial Steel Buildings", "url": {{ (site.url + "/steel-buildings/industrial/") | dump | safe }} } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Aircraft Hangars", "url": {{ (site.url + "/steel-buildings/aircraft-hangars/") | dump | safe }} } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Riding Arenas", "url": {{ (site.url + "/steel-buildings/arenas/") | dump | safe }} } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Mini-Storage Buildings", "url": {{ (site.url + "/steel-buildings/mini-storage/") | dump | safe }} } }
        ]
      }
    ]
  }
}
</script>
