---
layout: layouts/base.njk
title: Blog
description: "Tips, guides, and insights about pole barn construction, barndominiums, garage building, and more from CNO Pole Barns in Michigan."
permalink: /blog/
---

{# ========== BLOG LISTING PAGE — Cleean-inspired ========== #}

<section class="page-hero">
  <div class="container">
    <span class="section-label" style="color: var(--gold);">Our Blog</span>
    <h1>Insights &amp; Guides</h1>
    <p>Tips, guides, and project stories from over 55 years of pole barn building in Michigan.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    {# Featured post (first/latest) #}
    {% set featured = collections.blog | first %}
    {% if featured %}
    <a href="{{ featured.url }}" class="blog-featured fade-up">
      <div class="blog-featured-img">
        <img src="{{ featured.data.image or '/images/projects/pole-building.jpg' }}" alt="{{ featured.data.title }}">
      </div>
      <div class="blog-featured-content">
        <div class="blog-card-meta">
          <span>{{ featured.data.category or "Insights" }}</span>
          <span>{{ featured.data.date | dateFormat }}</span>
        </div>
        <h2>{{ featured.data.title }}</h2>
        <p>{{ featured.data.excerpt or (featured.templateContent | excerpt) }}</p>
        <span class="service-link">
          Read Article
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </span>
      </div>
    </a>
    {% endif %}

    {# Rest of posts #}
    <div class="blog-grid stagger-children" style="margin-top: 48px;">
      {% for post in collections.blog %}
      {% if not loop.first %}
      <a href="{{ post.url }}" class="blog-card fade-up">
        <div class="blog-card-img">
          <img src="{{ post.data.image or '/images/projects/pole-building.jpg' }}" alt="{{ post.data.title }}">
        </div>
        <div class="blog-card-body">
          <div class="blog-card-meta">
            <span>{{ post.data.category or "Insights" }}</span>
            <span>{{ post.data.date | dateFormat }}</span>
          </div>
          <h3>{{ post.data.title }}</h3>
          <p>{{ post.data.excerpt or (post.templateContent | excerpt) }}</p>
        </div>
      </a>
      {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
